{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],

    "paths": {
      "@/*": ["./backend/src/*"],
      "@database/*": ["./database/*"]
    },

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}