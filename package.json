{
  "name": "book-tracking-app",
  "version": "1.0.0",
  "description": "Aplicação para gerenciar leituras de livros",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "setup": "npm i && cd frontend && npm i && cd ..",
    "knex:latest": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./knexfile.ts",
    "knex:rollback": "npx tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile ./knexfile.ts"
  },
  "author": "Deivid Lopes",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^4.19.2",
    "knex": "^3.1.0",
    "sqlite3": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "concurrently": "^10.0.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
